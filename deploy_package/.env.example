# HTML Code Editor - 环境配置文件模板
# =============================================
# 安全警告：
# 1. 此文件包含敏感信息，切勿提交到版本控制系统
# 2. 请将此文件复制为 .env 并填写实际值
# 3. 生产环境建议使用环境变量而非此文件
# 4. 确保此文件权限设置为 600 (仅所有者可读写)
# =============================================

# 使用方法：
# cp .env.example .env
# chmod 600 .env
# 然后编辑 .env 文件填写实际配置

# =============================================
# 数据库配置
# =============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=html_editor
DB_USER=your_database_user
DB_PASS=your_secure_database_password_here
DB_CHARSET=utf8mb4

# =============================================
# 管理员账号
# 生产环境请使用强密码（至少16位，包含大小写、数字、特殊字符）
# 示例生成命令: openssl rand -base64 32
# =============================================
ADMIN_USER=admin
ADMIN_PASS=CHANGE_THIS_TO_A_STRONG_PASSWORD

# =============================================
# API密钥（用于签名验证）
# 请使用随机生成的密钥，不要使用默认值
# 示例生成命令: openssl rand -hex 32
# =============================================
PUBLISH_API_KEY=CHANGE_THIS_TO_A_RANDOM_KEY
HMAC_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY

# =============================================
# 调试模式（生产环境必须设为false）
# =============================================
DEBUG=false

# =============================================
# 部署检查清单：
# □ 修改所有默认密码
# □ 设置 DEBUG=false
# □ 确保 .env 文件权限为 600
# □ 将 .env 添加到 .gitignore
# □ 使用环境变量替代此文件（推荐）
# =============================================
